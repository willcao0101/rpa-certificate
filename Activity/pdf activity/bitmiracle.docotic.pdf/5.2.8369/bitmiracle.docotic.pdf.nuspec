    <id>BitMiracle.Docotic.Pdf</id>
    <version>5.2.8369</version>
    <title>Docotic.Pdf library</title>
    <authors>Bit Miracle</authors>
    <owners>Bit Miracle</owners>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>

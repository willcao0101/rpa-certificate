                            <OutArgument x:TypeArguments="x:Boolean" x:Key="isUnLock">[lockStatus]</OutArgument>
                            <InArgument x:TypeArguments="scg:Dictionary(x:String, x:Object)" x:Key="Config">[in_Config]</InArgument>
                          </ui:InvokeWorkflowFile.Arguments>
                        </ui:InvokeWorkflowFile>
                      </FlowStep>
                    </FlowDecision.True>
                    <FlowDecision.False>
                      <x:Reference>__ReferenceID0</x:Reference>
                    </FlowDecision.False>
                  </FlowDecision>
                </FlowStep.Next>
              </FlowStep>
            </FlowDecision.True>
            <FlowDecision.False>
              <FlowStep x:Name="__ReferenceID4" sap2010:WorkflowViewState.IdRef="FlowStep_3">
                <DoWhile sap2010:Annotation.AnnotationText="延时等待，直到锁标志不存在进行下一步" DisplayName="Do while" sap2010:WorkflowViewState.IdRef="DoWhile_1" Condition="[File.Exists(in_Config(&quot;Lockfile&quot;).ToString)]">
                  <Sequence DisplayName="Action" sap2010:WorkflowViewState.IdRef="Sequence_3">
                    <Sequence.Variables>
                      <Variable x:TypeArguments="x:TimeSpan" Name="DelayTime" />
                    </Sequence.Variables>
                    <Assign sap2010:WorkflowViewState.IdRef="Assign_3">
                      <Assign.To>
                        <OutArgument x:TypeArguments="x:TimeSpan">[DelayTime]</OutArgument>
                      </Assign.To>
                      <Assign.Value>
                        <InArgument x:TypeArguments="x:TimeSpan">[datetime.Now.AddMilliseconds(Cint(in_Config("UnlockRetryTime").ToString))-datetime.Now]</InArgument>
                      </Assign.Value>
                    </Assign>
                    <Delay Duration="[DelayTime]" sap2010:WorkflowViewState.IdRef="Delay_2" />
                  </Sequence>
                </DoWhile>
                <FlowStep.Next>
                  <FlowStep x:Name="__ReferenceID5" sap2010:WorkflowViewState.IdRef="FlowStep_4">
                    <ui:InvokeWorkflowFile ContinueOnError="{x:Null}" sap2010:Annotation.AnnotationText="加锁" DisplayName="Invoke workflow file" sap2010:WorkflowViewState.IdRef="InvokeWorkflowFile_1" UnSafe="False" WorkflowFileName="Framework\QueueWriteLock.xaml">

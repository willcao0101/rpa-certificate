  <Flowchart sap2010:Annotation.AnnotationText="Run Queue,if lock file is exists ,check mylocksign,if mylocksign TRUE then created by self, can del file,else wait,if lock file is not exists,create file and upated" DisplayName="QueueLockProcess" sap2010:WorkflowViewState.IdRef="Flowchart_1">

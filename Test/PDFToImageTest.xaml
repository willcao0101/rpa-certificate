g&gt;();&#xA;    //根据第二列的内容，找到指定的行和列&#xA;    for (int row = 1; row &lt; totalRow; row++)&#xA;    {&#xA;        Microsoft.Office.Interop.Excel.Range destRange = (Microsoft.Office.Interop.Excel.Range)xSheet.Cells[row, 2];&#xA;        if (destRange.Text.ToString().Trim().Contains(pageStr))&#xA;        {&#xA;            int destRow = row;&#xA;            Console.WriteLine(&quot;desRow: &quot; + row.ToString());&#xA;            xSheet.Cells[destRow, 3] = DateTime.Now.ToString(&quot;yyyy/MM/dd&quot;);&#xA;            xSheet.Cells[destRow, 4] = &quot;Andrew Zhai&quot;;&#xA;            xSheet.Cells[destRow, 5] = &quot;GC/SH/2021/000354&quot;;&#xA;            xSheet.Cells[destRow, 6] = &quot;SHES2109018149HS&quot;;&#xA;            break;&#xA;        }&#xA;    }&#xA;&#xA;    //5.保存保存WorkBook&#xA;    xBook.Save();&#xA;    //6.从内存中关闭Excel对象&#xA;    xSheet = null;&#xA;    xBook.Close();&#xA;    xBook = null;&#xA;    //关闭EXCEL的提示框&#xA;    xApp.DisplayAlerts = false;&#xA;    //Excel从内存中退出&#xA;    xApp.Quit();&#xA;    xApp = null;&#xA;&#x9;&#xA;}" DisplayName="Invoke code" sap:VirtualizedContainerService.HintSize="200,93" sap2010:WorkflowViewState.IdRef="InvokeCode_6" Language="CSharp">

quot;###不需要检查For CS文件夹中的Word###&quot;);&#xA;&#x9;}&#xA;&#x9;&#xA;&#x9;//对于pdf文件，需要emailProcertList的“最后”中需要加上无Procert系统推送邮件的CE证书的信息&#xA;&#x9;//if((Convert.ToInt32(in_emailTADict[&quot;CertificateCount&quot;]) - in_emailProcertList.Count) == 1){&#xA;&#x9;//if(in_emailTADict[&quot;CertificateType&quot;].Contains(&quot;CE&quot;)){&#xA;&#x9;&#x9;//in_emailTADict[&quot;OfflineCertificateCount&quot;] = (Convert.ToInt32(in_emailTADict[&quot;OfflineCertificateCount&quot;]) + 1).ToString();&#xA;&#x9;//}&#x9;&#xA;&#x9;Regex reg = new Regex(&quot;.*[0-9]+[A-Z]{2}.pdf$|.*[0-9]+[A-Z]{2}A[0-9]{2}.pdf$&quot;);&#xA;&#x9;if(in_emailTADict[&quot;CertificateType&quot;].Contains(&quot;CE&quot;) &amp;&amp; in_emailTADict[&quot;CECertificateAdd&quot;] == &quot;0&quot;){&#xA;&#x9;&#x9;Console.WriteLine(&quot;###需要检查For CS文件夹中的PDF###&quot;);&#xA;&#x9;&#x9;string[] pdfFiles = Directory.GetFiles(in_emailTADict[&quot;CSDirectory&quot;] + @&quot;\&quot;, &quot;*.pdf*&quot;);&#xA;&#x9;&#x9;foreach(string pdfFile in pdfFiles){&#xA;&#x9;&#x9;&#x9;string fileName = Path.GetFileName(pdfFile);&#xA;&#x9;&#x9;&#x9;//其他类型的CE证书&#xA;&#x9;&#x9;&#x9;//string filePath = @&quot;C:\Users\RPA-CA.SHEEC\Desktop\temp\DSS_SHES2210018765ATA01.pdf&quot;;&#xA;&#x9;&#x9;&#x9;//string fileName = Path.GetFileNameWithoutExtension(filePath);&#xA;&#x9;&#x9;&#x9;//Console.WriteLine(fileName);&#xA;&#x9;&#x9;&#x9;&#xA;&#x9;&#x9;&#x9;bool isMatchFlag = reg.IsMatch(fileName);&#xA;&#x9;&#x9;&#x9;Console.WriteLine(isMatchFlag.ToString());&#xA;&#x9;&#x9;&#x9;&#xA;&#x9;&#x9;&#x9;//if (fileName.StartsWith(&quot;UKCA&quot;) || fileName.StartsWith(&quot;VOC&quot;) || fileName.StartsWith(&quot;LVD&quot;) || fileName.StartsWith(&quot;MD&quot;) || fileName.StartsWith(&quot;RED&quot;) || fileName.StartsWith(&quot;ErP&quot;) || fileName.StartsWith(&quot;UKCA LVD&quot;) || fileName.StartsWith(&quot;UKCA MD&quot;) || fileName.StartsWith(&quot;UKCA RED&quot;) || fileName.StartsWith(&quot;UKCA GPSD&quot;)){&#xA;&#x9;&#x9;&#x9;if (fileName.StartsWith(&quot;UKCA&quot;) || fileName.StartsWith(&quot;VOC&quot;) || fileName.StartsWith(&quot;LVD&quot;) || fileName.StartsWith(&quot;MD&quot;) || fileName.StartsWith(&quot;RED&quot;) || fileName.StartsWith(&quot;ErP&quot;) || fileName.StartsWith(&quot;GPSD&quot;) || isMatchFlag){&#xA;&#x9;&#x9;&#x9;&#x9;&#xA;&#x9;&#x9;&#x9;&#x9;Dictionary&lt;string, string&gt; tempProcertDict = new Dictionary&lt;string, string&gt;();&#xA;&#x9;&#x9;&#x9;&#x9;//后续如果还需要用到什么信息，可以在此处添加&#xA;&#x9;&#x9;&#x9;&#x9;tempProcertDict[&quot;CertificatePath&quot;] = pdfFile;&#xA;&#x9;&#x9;&#x9;&#x9;tempProcertDict[&quot;Certificate No.&quot;] = Path.GetFileNameWithoutExtension(pdfFile);&#xA;&#x9;&#x9;&#x9;&#x9;tempProcertDict[&quot;HandleFlag&quot;] = &quot;0&quot;;&#xA;&#x9;&#x9;&#x9;&#x9;//获取文件最后的访问时间&#xA;&#x9;&#x9;&#x9;&#x9;FileInfo fi = new FileInfo(pdfFile);&#xA;&#x9;&#x9;&#x9;&#x9;DateTime time = fi.LastAccessTime;&#xA;&#x9;&#x9;&#x9;&#x9;Console.WriteLine(time.ToString(&quot;yyyy-M-d&quot;));&#xA;&#x9;&#x9;&#x9;&#x9;string dateStr = time.ToString(&quot;yyyy-M-d&quot;);&#xA;&#x9;&#x9;&#x9;&#x9;tempProcertDict[&quot;yearDir&quot;] = dateStr.Split('-')[0];&#xA;&#x9;&#x9;&#x9;&#x9;tempProcertDict[&quot;monthDir&quot;] = dateStr.Split('-')[1];&#xA;&#x9;&#x9;&#x9;&#x9;tempProcertDict[&quot;dateDir&quot;] = time.ToString(&quot;M-d&quot;);&#xA;&#x9;&#x9;&#x9;&#x9;&#xA;&#x9;&#x9;&#x9;&#x9;if(fileName.StartsWith(&quot;UKCA&quot;)){&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;tempProcertDict[&quot;Scheme&quot;] = &quot;UKCA&quot;;&#xA;&#x9;&#x9;&#x9;&#x9;}else if(fileName.StartsWith(&quot;VOC&quot;)){&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;tempProcertDict[&quot;Scheme&quot;] = &quot;VOC&quot;;&#xA;&#x9;&#x9;&#x9;&#x9;}else if(fileName.StartsWith(&quot;LVD&quot;)){&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;tempProcertDict[&quot;Scheme&quot;] = &quot;LVD&quot;;&#xA;&#x9;&#x9;&#x9;&#x9;}else if(fileName.StartsWith(&quot;MD&quot;)){&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;tempProcertDict[&quot;Scheme&quot;] = &quot;MD&quot;;&#xA;&#x9;&#x9;&#x9;&#x9;}else
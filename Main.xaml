                                                                                                                        <ui:InvokeCode ContinueOnError="{x:Null}" sap2010:Annotation.AnnotationText="将识别得到的证书空值页码写入到指定Excel中" Code="Regex reg = new Regex(@&quot;.*\((\d*)-(\d*)\).*&quot;);&#xA;//List&lt;string&gt; pageStrList = new List&lt;string&gt; {&quot;20623033&quot;, &quot;20624034&quot;, &quot;20625035&quot; };&#xA;//string destDir = @&quot;C:\Users\will-w_cao\Desktop\aaa&quot;;&#xA;&#xA;foreach (string pageStr in in_pageStrList)&#xA;{&#xA;    //遍历目标文件夹，找到指定的excel&#xA;    string[] filePathArr = Directory.GetFiles(in_destDir);&#xA;    string destExcel = string.Empty;&#xA;    foreach (string filePath in filePathArr)&#xA;    {&#xA;        string fileName = Path.GetFileNameWithoutExtension(filePath);&#xA;        Match match = reg.Match(fileName);&#xA;        string pageStart = match.Groups[1].Value.Trim();&#xA;        string pageEnd = match.Groups[2].Value.Trim();&#xA;        //Console.WriteLine(pageStart+&quot;-&quot;+pageEnd);&#xA;        if (Convert.ToInt32(pageStart) &lt;= Convert.ToInt32(pageStr) &amp;&amp; Convert.ToInt32(pageStr) &lt;= Convert.ToInt32(pageEnd))&#xA;        {&#xA;            destExcel = filePath;&#xA;            break;&#xA;        }&#xA;    }&#xA;&#xA;    Console.WriteLine(&quot;destExcel: &quot;+destExcel);&#xA;    //将管控页码写入到Excel中&#xA;   //将数据写入到Excel中&#xA;&#x9;&#xA;&#x9;&#xA;&#x9;//待封装函数&#xA;    //1.创建Applicaton对象&#xA;    Microsoft.Office.Interop.Excel.Application xApp = new Microsoft.Office.Interop.Excel.Application();&#xA;    //2.得到workbook对象，打开已有的文件&#xA;    Microsoft.Office.Interop.Excel.Workbook xBook = xApp.Workbooks.Open(destExcel);&#xA;    //3.指定要操作的Sheet&#xA;    Microsoft.Office.Interop.Excel.Worksheet xSheet = (Microsoft.Office.Interop.Excel.Worksheet)xBook.Sheets[1];&#xA;    //4.向相应对位置写入相应的数据&#xA;    int totalRow = xSheet.UsedRange.Rows.Count;&#xA;    int totalCol = xSheet.UsedRange.Columns.Count;&#xA;&#xA;    //bool signFlag = true;&#xA;    List&lt;string&gt; signList = new List&lt;string&gt;();&#xA;    List&lt;string&gt; lockList = new List&lt;string&gt;();&#xA;    //根据第二列的内容，找到指定的行和列&#xA;    for (int row = 1; row &lt; totalRow; row++)&#xA;    {&#xA;        Microsoft.Office.Interop.Excel.Range destRange = (Microsoft.Office.Interop.Excel.Range)xSheet.Cells[row, 2];&#xA;        if (destRange.Text.ToString().Trim().Contains(pageStr))&#xA;        {&#xA;            int destRow = row;&#xA;            Console.WriteLine(&quot;desRow: &quot; + row.ToString());&#xA;            xSheet.Cells[destRow, 3] = DateTime.Now.ToString(&quot;yyyy/MM/dd&quot;);&#xA;            xSheet.Cells[destRow, 4] = &quot;Andrew Zhai&quot;;&#xA;            xSheet.Cells[destRow, 5] = in_emailProcertList[0][&quot;Certificate No.&quot;];&#xA;            xSheet.Cells[destRow, 6] = in_emailProcertList[0][&quot;Import Record No.&quot;];&#xA;            break;&#xA;        }&#xA;    }&#xA;&#xA;    //5.保存保存WorkBook&#xA;    xBook.Save();&#xA;    //6.从内存中关闭Excel对象&#xA;    xSheet = null;&#xA;    xBook.Close();&#xA;    xBook = null;&#xA;    //关闭EXCEL的提示框&#xA;    xApp.DisplayAlerts = false;&#xA;    //Excel从内存中退出&#xA;    xApp.Quit();&#xA;    xApp = null;&#xA;&#x9;&#xA;}" DisplayName="Invoke code" sap:VirtualizedContainerService.HintSize="334,196" sap2010:WorkflowViewState.IdRef="InvokeCode_26" Language="CSharp">
